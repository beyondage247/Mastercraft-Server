<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Quote {{quoteId}}</title>
  </head>
  <body
    style='
      margin: 0;
      padding: 0;
      background-color: #f4f0ea;
      font-family: Arial, Helvetica, sans-serif;
      color: #24303b;
    '
  >
    <table
      role='presentation'
      width='100%'
      cellpadding='0'
      cellspacing='0'
      style='background-color: #f4f0ea; padding: 32px 12px'
    >
      <tr>
        <td align='center'>
          <table
            role='presentation'
            width='100%'
            cellpadding='0'
            cellspacing='0'
            style='
              max-width: 820px;
              background-color: #ffffff;
              border-collapse: collapse;
              box-shadow: 0 14px 38px rgba(36, 48, 59, 0.08);
            '
          >
            <tr>
              <td style='padding: 40px 42px 28px'>
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                >
                  <tr>
                    <td
                      colspan='2'
                      align='center'
                      style='vertical-align: top; padding-bottom: 22px'
                    >
                      <img
                        src='https://res.cloudinary.com/dqe4xzwoe/image/upload/v1781170296/Others/WhatsApp_Image_2026-06-10_at_1.34.02_PM-removebg-preview_u874ju.png'
                        alt='Mastercraft Products'
                        style='display: block; width: 480px; max-width: 100%; height: auto; margin: 0 auto 18px'
                      />
                    </td>
                  </tr>
                  <tr>
                    <td style='vertical-align: top'>
                      <p
                        style='
                          margin: 0 0 10px;
                          font-size: 12px;
                          letter-spacing: 0.14em;
                          text-transform: uppercase;
                          color: #7f8b96;
                        '
                      >
                        Quote Summary
                      </p>
                      <p
                        style='
                          margin: 0 0 18px;
                          font-size: 18px;
                          font-weight: 700;
                          color: #24303b;
                        '
                      >
                        {{quoteName}}
                      </p>
                    </td>
                    <td align='right' style='vertical-align: top'>
                      <p
                        style='
                          margin: 0 0 8px;
                          font-size: 13px;
                          color: #7f8b96;
                        '
                      >
                        Quote
                      </p>
                      <p
                        style='
                          margin: 0 0 18px;
                          font-size: 24px;
                          font-weight: 700;
                          color: #24303b;
                        '
                      >
                        {{quoteId}}
                      </p>
                      <p
                        style='
                          margin: 0 0 4px;
                          font-size: 13px;
                          color: #7f8b96;
                        '
                      >
                        Issue date
                      </p>
                      <p style='margin: 0; font-size: 15px; color: #24303b'>
                        {{dateIssued}}
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style='padding: 0 42px'>
                <div style='height: 6px; background-color: #c90000'></div>
              </td>
            </tr>

            <tr>
              <td style='padding: 34px 42px 18px'>
                <h1
                  style='
                    margin: 0 0 12px;
                    font-size: 28px;
                    line-height: 1.2;
                    color: #24303b;
                  '
                >
                  {{projectName}}
                </h1>
                <p
                  style='
                    margin: 0;
                    font-size: 17px;
                    line-height: 1.7;
                    color: #4d5a67;
                  '
                >
                  We look forward to working with you. Below is the quote
                  summary prepared for
                  {{recipientName}}.
                </p>
              </td>
            </tr>

            <tr>
              <td style='padding: 0 42px 24px'>
                <table
                  role='presentation'
                  cellpadding='0'
                  cellspacing='0'
                  style='border-collapse: collapse'
                >
                  <tr>
                    <td
                      style='
                        background-color: #c90000;
                        border-radius: 999px;
                      '
                    >
                      <a
                        href='{{portalUrl}}'
                        style='
                          display: inline-block;
                          padding: 14px 24px;
                          font-size: 14px;
                          font-weight: 700;
                          color: #ffffff;
                          text-decoration: none;
                        '
                      >
                        View Quote
                      </a>
                    </td>
                    <td style='padding-left: 12px'>
                      <a
                        href='{{quoteDownloadUrl}}'
                        style='
                          display: inline-block;
                          padding: 13px 24px;
                          font-size: 14px;
                          font-weight: 700;
                          color: #c90000;
                          text-decoration: none;
                          border: 1px solid #c90000;
                          border-radius: 999px;
                        '
                      >
                        Download Quote PDF
                      </a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style='padding: 0 42px 18px'>
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  style='border-collapse: collapse'
                >
                  <tr>
                    <td
                      width='50%'
                      style='
                        padding: 18px 12px 18px 0;
                        border-top: 1px solid #d9e0e6;
                        border-bottom: 1px solid #d9e0e6;
                        vertical-align: top;
                      '
                    >
                      <p
                        style='
                          margin: 0 0 12px;
                          font-size: 13px;
                          font-weight: 700;
                          color: #24303b;
                        '
                      >
                        Customer
                      </p>
                      <p
                        style='
                          margin: 0 0 4px;
                          font-size: 15px;
                          line-height: 1.6;
                          color: #4d5a67;
                        '
                      >
                        {{recipientName}}
                      </p>
                      {{#if clientCompany}}
                        <p
                          style='
                          margin: 0 0 4px;
                          font-size: 15px;
                          line-height: 1.6;
                          color: #4d5a67;
                        '
                        >
                          {{clientCompany}}
                        </p>
                      {{/if}}
                      <p
                        style='
                          margin: 0 0 4px;
                          font-size: 15px;
                          line-height: 1.6;
                          color: #4d5a67;
                        '
                      >
                        {{recipientEmail}}
                      </p>
                      {{#if clientPhone}}
                        <p
                          style='
                          margin: 0;
                          font-size: 15px;
                          line-height: 1.6;
                          color: #4d5a67;
                        '
                        >
                          {{clientPhone}}
                        </p>
                      {{/if}}
                    </td>
                    <td
                      width='50%'
                      style='
                        padding: 18px 0 18px 12px;
                        border-top: 1px solid #d9e0e6;
                        border-bottom: 1px solid #d9e0e6;
                        vertical-align: top;
                      '
                    >
                      <p
                        style='
                          margin: 0 0 12px;
                          font-size: 13px;
                          font-weight: 700;
                          color: #24303b;
                        '
                      >
                        Quote Details
                      </p>
                      <p
                        style='
                          margin: 0 0 4px;
                          font-size: 15px;
                          line-height: 1.6;
                          color: #4d5a67;
                        '
                      >
                        {{quoteName}}
                      </p>
                      <p
                        style='
                          margin: 0 0 4px;
                          font-size: 15px;
                          line-height: 1.6;
                          color: #4d5a67;
                        '
                      >
                        Valid until
                        {{validUntil}}
                      </p>
                      {{#if projectLocation}}
                        <p
                          style='
                          margin: 0 0 4px;
                          font-size: 15px;
                          line-height: 1.6;
                          color: #4d5a67;
                        '
                        >
                          {{projectLocation}}
                        </p>
                      {{/if}}
                      <p
                        style='
                          margin: 8px 0 0;
                          font-size: 26px;
                          font-weight: 700;
                          line-height: 1.3;
                          color: #24303b;
                        '
                      >
                        {{total}}
                      </p>
                      {{#if paymentScheduleLabel}}
                        <p
                          style='
                          margin: 4px 0 0;
                          font-size: 14px;
                          line-height: 1.6;
                          color: #7f8b96;
                        '
                        >
                          {{paymentScheduleLabel}}
                        </p>
                      {{/if}}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            {{#if message}}
              <tr>
                <td style='padding: 0 42px 24px'>
                  <table
                    role='presentation'
                    width='100%'
                    cellpadding='0'
                    cellspacing='0'
                    style='
                      border-collapse: collapse;
                      border: 1px solid #d9e0e6;
                      background-color: #fafcfd;
                    '
                  >
                    <tr>
                      <td style='padding: 20px 22px'>
                        <p
                          style='
                            margin: 0 0 8px;
                            font-size: 13px;
                            font-weight: 700;
                            letter-spacing: 0.06em;
                            text-transform: uppercase;
                            color: #607080;
                          '
                        >
                          Message
                        </p>
                        <p
                          style='
                            margin: 0;
                            font-size: 15px;
                            line-height: 1.8;
                            color: #4d5a67;
                          '
                        >
                          {{message}}
                        </p>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            {{/if}}

            <tr>
              <td style='padding: 0 42px 8px'>
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  style='border-collapse: collapse'
                >
                  <tr>
                    <td
                      style='
                        padding: 0 0 12px;
                        font-size: 13px;
                        font-weight: 700;
                        color: #24303b;
                      '
                    >
                      Items
                    </td>
                  </tr>
                </table>
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  style='border-collapse: collapse'
                >
                  <tr style='background-color: #f6f8fa'>
                    <td
                      style='
                        padding: 14px 12px;
                        font-size: 13px;
                        font-weight: 700;
                        color: #24303b;
                        border-top: 1px solid #d9e0e6;
                        border-bottom: 1px solid #d9e0e6;
                      '
                    >
                      Item
                    </td>
                    <td
                      align='center'
                      style='
                        padding: 14px 12px;
                        font-size: 13px;
                        font-weight: 700;
                        color: #24303b;
                        border-top: 1px solid #d9e0e6;
                        border-bottom: 1px solid #d9e0e6;
                      '
                    >
                      Quantity
                    </td>
                    <td
                      align='right'
                      style='
                        padding: 14px 12px;
                        font-size: 13px;
                        font-weight: 700;
                        color: #24303b;
                        border-top: 1px solid #d9e0e6;
                        border-bottom: 1px solid #d9e0e6;
                      '
                    >
                      Price
                    </td>
                    <td
                      align='right'
                      style='
                        padding: 14px 0 14px 12px;
                        font-size: 13px;
                        font-weight: 700;
                        color: #24303b;
                        border-top: 1px solid #d9e0e6;
                        border-bottom: 1px solid #d9e0e6;
                      '
                    >
                      Amount
                    </td>
                  </tr>
                  {{#each lineItems}}
                    <tr>
                      <td
                        style='
                        padding: 14px 12px;
                        font-size: 15px;
                        line-height: 1.6;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        {{productName}}
                      </td>
                      <td
                        align='center'
                        style='
                        padding: 14px 12px;
                        font-size: 15px;
                        line-height: 1.6;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        {{quantity}}
                      </td>
                      <td
                        align='right'
                        style='
                        padding: 14px 12px;
                        font-size: 15px;
                        line-height: 1.6;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        {{#if price}}{{price}}{{else}}TBD{{/if}}
                      </td>
                      <td
                        align='right'
                        style='
                        padding: 14px 0 14px 12px;
                        font-size: 15px;
                        line-height: 1.6;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        {{#if amount}}{{amount}}{{else}}TBD{{/if}}
                      </td>
                    </tr>
                  {{/each}}
                </table>
              </td>
            </tr>

            <tr>
              <td style='padding: 4px 42px 0'>
                <table
                  role='presentation'
                  align='right'
                  cellpadding='0'
                  cellspacing='0'
                  style='min-width: 280px; border-collapse: collapse'
                >
                  <tr>
                    <td
                      style='
                        padding: 10px 18px 10px 0;
                        font-size: 15px;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                    >
                      Subtotal
                    </td>
                    <td
                      align='right'
                      style='
                        padding: 10px 0;
                        font-size: 15px;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                    >
                      {{subtotal}}
                    </td>
                  </tr>
                  {{#if showTax}}
                    <tr>
                      <td
                        style='
                        padding: 10px 18px 10px 0;
                        font-size: 15px;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        {{taxLabel}}
                      </td>
                      <td
                        align='right'
                        style='
                        padding: 10px 0;
                        font-size: 15px;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        {{taxAmount}}
                      </td>
                    </tr>
                  {{/if}}
                  {{#if showDiscount}}
                    <tr>
                      <td
                        style='
                        padding: 10px 18px 10px 0;
                        font-size: 15px;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        Discount
                      </td>
                      <td
                        align='right'
                        style='
                        padding: 10px 0;
                        font-size: 15px;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        -{{discount}}
                      </td>
                    </tr>
                  {{/if}}
                  {{#if showShippingFee}}
                    <tr>
                      <td
                        style='
                        padding: 10px 18px 10px 0;
                        font-size: 15px;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        Shipping
                      </td>
                      <td
                        align='right'
                        style='
                        padding: 10px 0;
                        font-size: 15px;
                        color: #4d5a67;
                        border-bottom: 1px solid #edf1f4;
                      '
                      >
                        {{shippingFee}}
                      </td>
                    </tr>
                  {{/if}}
                  <tr>
                    <td
                      style='
                        padding: 14px 18px 0 0;
                        font-size: 18px;
                        font-weight: 700;
                        color: #24303b;
                      '
                    >
                      Total
                    </td>
                    <td
                      align='right'
                      style='
                        padding: 14px 0 0;
                        font-size: 22px;
                        font-weight: 700;
                        color: #24303b;
                      '
                    >
                      {{total}}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            {{#if hasPaymentSchedule}}
              <tr>
                <td style='padding: 36px 42px 0'>
                  <table
                    role='presentation'
                    width='100%'
                    cellpadding='0'
                    cellspacing='0'
                    style='
                    border-collapse: collapse;
                    border: 1px solid #d9e0e6;
                    background-color: #fbfcfd;
                  '
                  >
                    <tr>
                      <td style='padding: 20px 22px 14px'>
                        <p
                          style='
                          margin: 0;
                          font-size: 13px;
                          font-weight: 700;
                          color: #24303b;
                        '
                        >
                          {{#if
                            paymentScheduleLabel
                          }}{{paymentScheduleLabel}}{{else}}Payment Schedule{{/if}}
                        </p>
                      </td>
                    </tr>
                    <tr style='background-color: #f2f5f8'>
                      <td style='padding: 0 22px'>
                        <table
                          role='presentation'
                          width='100%'
                          cellpadding='0'
                          cellspacing='0'
                          style='border-collapse: collapse'
                        >
                          <tr>
                            <td
                              style='
                              padding: 12px 0;
                              font-size: 12px;
                              font-weight: 700;
                              text-transform: uppercase;
                              color: #607080;
                              border-bottom: 1px solid #d9e0e6;
                            '
                            >
                              Milestone
                            </td>
                            <td
                              align='right'
                              style='
                              padding: 12px 0;
                              font-size: 12px;
                              font-weight: 700;
                              text-transform: uppercase;
                              color: #607080;
                              border-bottom: 1px solid #d9e0e6;
                            '
                            >
                              Due Date
                            </td>
                            <td
                              align='right'
                              style='
                              padding: 12px 0 12px 18px;
                              font-size: 12px;
                              font-weight: 700;
                              text-transform: uppercase;
                              color: #607080;
                              border-bottom: 1px solid #d9e0e6;
                            '
                            >
                              Share
                            </td>
                            <td
                              align='right'
                              style='
                              padding: 12px 0 12px 18px;
                              font-size: 12px;
                              font-weight: 700;
                              text-transform: uppercase;
                              color: #607080;
                              border-bottom: 1px solid #d9e0e6;
                            '
                            >
                              Amount
                            </td>
                          </tr>
                          {{#each paymentScheduleItems}}
                            <tr>
                              <td
                                style='
                              padding: 14px 0;
                              font-size: 15px;
                              line-height: 1.6;
                              color: #4d5a67;
                              border-bottom: 1px solid #edf1f4;
                            '
                              >
                                {{name}}
                              </td>
                              <td
                                align='right'
                                style='
                              padding: 14px 0;
                              font-size: 15px;
                              line-height: 1.6;
                              color: #4d5a67;
                              border-bottom: 1px solid #edf1f4;
                            '
                              >
                                {{dueDate}}
                              </td>
                              <td
                                align='right'
                                style='
                              padding: 14px 0 14px 18px;
                              font-size: 15px;
                              line-height: 1.6;
                              color: #4d5a67;
                              border-bottom: 1px solid #edf1f4;
                            '
                              >
                                {{percentage}}
                              </td>
                              <td
                                align='right'
                                style='
                              padding: 14px 0 14px 18px;
                              font-size: 15px;
                              line-height: 1.6;
                              color: #4d5a67;
                              border-bottom: 1px solid #edf1f4;
                            '
                              >
                                {{amount}}
                              </td>
                            </tr>
                          {{/each}}
                        </table>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            {{/if}}

            {{#if contactEmail}}
              <tr>
                <td style='padding: 28px 42px 0'>
                  <table
                    role='presentation'
                    width='100%'
                    cellpadding='0'
                    cellspacing='0'
                    style='
                    border-collapse: collapse;
                    background-color: #f8fafb;
                    border: 1px solid #d9e0e6;
                  '
                  >
                    <tr>
                      <td style='padding: 22px'>
                        <p
                          style='
                          margin: 0 0 10px;
                          font-size: 13px;
                          font-weight: 700;
                          color: #24303b;
                        '
                        >
                          Questions About This Quote?
                        </p>
                        <p
                          style='
                          margin: 0;
                          font-size: 15px;
                          line-height: 1.7;
                          color: #4d5a67;
                        '
                        >
                          Contact
                          {{#if contactName}}{{contactName}}{{else}}your account
                            partner{{/if}}
                          at
                          {{contactEmail}}
                          or call
                          {{companyPhone}}.
                        </p>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            {{/if}}

            <tr>
              <td
                style='
                  padding: 28px 42px 34px;
                  font-size: 14px;
                  line-height: 1.7;
                  color: #7f8b96;
                '
              >
                This is an automated quote notification. Please use your normal
                project contact for any follow-up questions or call
                {{companyPhone}}.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
