<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Project Updated</title>
  </head>
  <body
    style='
      margin: 0;
      padding: 0;
      background-color: #eef2f7;
      font-family: Arial, Helvetica, sans-serif;
      color: #1f2937;
    '
  >
    <table
      role='presentation'
      width='100%'
      cellpadding='0'
      cellspacing='0'
      style='background-color: #eef2f7; padding: 32px 16px'
    >
      <tr>
        <td align='center'>
          <table
            role='presentation'
            width='100%'
            cellpadding='0'
            cellspacing='0'
            style='
              max-width: 680px;
              background-color: #ffffff;
              border-radius: 16px;
              overflow: hidden;
              box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
            '
          >
            <tr>
              <td
                style='
                  background-color: #ffffff;
                  padding: 28px 40px 24px;
                  color: #1f2937;
                '
              >
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                >
                  <tr>
                    <td colspan='3' align='center' style='padding-bottom: 20px'>
                      <img
                        src='https://res.cloudinary.com/dqe4xzwoe/image/upload/v1781170296/Others/WhatsApp_Image_2026-06-10_at_1.34.02_PM-removebg-preview_u874ju.png'
                        alt='Mastercraft Products'
                        style='display: block; width: 440px; max-width: 100%; height: auto; margin: 0 auto'
                      />
                    </td>
                  </tr>
                  <tr>
                    <td colspan='2' style='vertical-align: middle'>
                      <p
                        style='
                          margin: 0 0 8px;
                          font-size: 12px;
                          letter-spacing: 0.14em;
                          text-transform: uppercase;
                          color: #7f8b96;
                        '
                      >
                        Project Updated
                      </p>
                      <h1
                        style='
                          margin: 0;
                          font-size: 24px;
                          line-height: 1.3;
                          color: #1f2937;
                        '
                      >
                        {{projectName}}
                      </h1>
                    </td>
                    <td align='right' style='vertical-align: top'>
                      <p style='margin: 0; font-size: 14px; color: #7f8b96'>
                        Updated for
                        {{recipientName}}
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style='padding: 0 40px'>
                <div style='height: 4px; background-color: #c90000'></div>
              </td>
            </tr>

            <tr>
              <td style='padding: 32px 40px 12px'>
                <p style='margin: 0; font-size: 16px; line-height: 1.7'>
                  Your project has been updated by our team. The latest changes
                  currently on file affect
                  <strong>{{updatedSummary}}</strong>.
                </p>
              </td>
            </tr>

            <tr>
              <td style='padding: 8px 40px 0'>
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  style='border-collapse: collapse; border: 1px solid #d7dee7'
                >
                  <tr>
                    <td
                      style='
                        width: 50%;
                        padding: 16px;
                        border-right: 1px solid #d7dee7;
                        border-bottom: 1px solid #d7dee7;
                      '
                    >
                      <p
                        style='
                          margin: 0 0 6px;
                          font-size: 12px;
                          text-transform: uppercase;
                          letter-spacing: 0.08em;
                          color: #64748b;
                        '
                      >
                        Customer
                      </p>
                      <p style='margin: 0; font-size: 15px; line-height: 1.6'>
                        {{recipientName}}
                      </p>
                    </td>
                    <td
                      style='
                        width: 50%;
                        padding: 16px;
                        border-bottom: 1px solid #d7dee7;
                      '
                    >
                      <p
                        style='
                          margin: 0 0 6px;
                          font-size: 12px;
                          text-transform: uppercase;
                          letter-spacing: 0.08em;
                          color: #64748b;
                        '
                      >
                        Location
                      </p>
                      <p style='margin: 0; font-size: 15px; line-height: 1.6'>
                        {{location}}
                      </p>
                    </td>
                  </tr>
                  <tr>
                    <td
                      style='
                        width: 50%;
                        padding: 16px;
                        border-right: 1px solid #d7dee7;
                        border-bottom: 1px solid #d7dee7;
                      '
                    >
                      <p
                        style='
                          margin: 0 0 6px;
                          font-size: 12px;
                          text-transform: uppercase;
                          letter-spacing: 0.08em;
                          color: #64748b;
                        '
                      >
                        Start Date
                      </p>
                      <p style='margin: 0; font-size: 15px; line-height: 1.6'>
                        {{startDate}}
                      </p>
                    </td>
                    <td
                      style='
                        width: 50%;
                        padding: 16px;
                        border-bottom: 1px solid #d7dee7;
                      '
                    >
                      <p
                        style='
                          margin: 0 0 6px;
                          font-size: 12px;
                          text-transform: uppercase;
                          letter-spacing: 0.08em;
                          color: #64748b;
                        '
                      >
                        End Date
                      </p>
                      <p style='margin: 0; font-size: 15px; line-height: 1.6'>
                        {{endDate}}
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style='padding: 24px 40px 0'>
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  style='
                    border: 1px solid #d7dee7;
                    background-color: #f8fafc;
                    border-radius: 12px;
                  '
                >
                  <tr>
                    <td style='padding: 24px'>
                      <p
                        style='
                          margin: 0 0 10px;
                          font-size: 12px;
                          text-transform: uppercase;
                          letter-spacing: 0.08em;
                          color: #64748b;
                        '
                      >
                        Update Summary
                      </p>
                      <p style='margin: 0 0 12px; font-size: 15px; line-height: 1.7'>
                        <strong>Current Status:</strong>
                        {{projectStatus}}
                      </p>
                      <p style='margin: 0; font-size: 15px; line-height: 1.7'>
                        <strong>Updated Sections:</strong>
                        {{updatedSummary}}
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style='padding: 24px 40px 0'>
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  style='
                    border: 1px solid #d7dee7;
                    background-color: #f8fafc;
                    border-radius: 12px;
                  '
                >
                  <tr>
                    <td style='padding: 24px'>
                      <p
                        style='
                          margin: 0 0 10px;
                          font-size: 12px;
                          text-transform: uppercase;
                          letter-spacing: 0.08em;
                          color: #64748b;
                        '
                      >
                        Project Scope
                      </p>
                      <p
                        style='
                          margin: 0 0 16px;
                          font-size: 15px;
                          line-height: 1.7;
                        '
                      >
                        {{description}}
                      </p>
                      <p style='margin: 0; font-size: 15px; line-height: 1.7'>
                        <strong>Fabrication:</strong>
                        {{fabrication}}
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td
                style='
                  padding: 24px 40px 32px;
                  font-size: 14px;
                  line-height: 1.7;
                  color: #475569;
                '
              >
                We will keep you updated as this project progresses. Please
                contact the team at {{companyPhone}} if any of the details
                above need to be changed.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
