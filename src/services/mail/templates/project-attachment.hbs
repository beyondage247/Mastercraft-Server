<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Project Documents Updated</title>
  </head>
  <body
    style='
      margin: 0;
      padding: 0;
      background-color: #f4f7fb;
      font-family: Arial, Helvetica, sans-serif;
      color: #1f2937;
    '
  >
    <table
      role='presentation'
      width='100%'
      cellpadding='0'
      cellspacing='0'
      style='background-color: #f4f7fb; padding: 32px 16px'
    >
      <tr>
        <td align='center'>
          <table
            role='presentation'
            width='100%'
            cellpadding='0'
            cellspacing='0'
            style='
              max-width: 640px;
              background-color: #ffffff;
              border-radius: 16px;
              overflow: hidden;
              box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
            '
          >
            <tr>
              <td
                style='
                  background-color: #ffffff;
                  padding: 28px 40px 24px;
                  color: #1f2937;
                '
              >
                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                >
                  <tr>
                    <td align='center' style='padding-bottom: 20px'>
                      <img
                        src='https://res.cloudinary.com/dqe4xzwoe/image/upload/v1781170296/Others/WhatsApp_Image_2026-06-10_at_1.34.02_PM-removebg-preview_u874ju.png'
                        alt='Mastercraft Products'
                        style='display: block; width: 440px; max-width: 100%; height: auto; margin: 0 auto'
                      />
                    </td>
                  </tr>
                  <tr>
                    <td style='vertical-align: middle; text-align: right'>
                      <p
                        style='
                          margin: 0 0 8px;
                          font-size: 12px;
                          letter-spacing: 0.12em;
                          text-transform: uppercase;
                          color: #7f8b96;
                        '
                      >
                        Project Documents
                      </p>
                      <h1
                        style='
                          margin: 0;
                          font-size: 28px;
                          line-height: 1.3;
                          color: #1f2937;
                        '
                      >
                        Hello,
                        {{recipientName}}
                      </h1>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style='padding: 0 40px'>
                <div style='height: 4px; background-color: #c90000'></div>
              </td>
            </tr>

            <tr>
              <td style='padding: 32px 40px'>
                <p style='margin: 0 0 16px; font-size: 16px; line-height: 1.7'>
                  Documents were added to the project
                  <strong>{{projectName}}</strong>.
                </p>

                <p style='margin: 0 0 16px; font-size: 15px; line-height: 1.7'>
                  <strong>{{uploaderName}}</strong>
                  ({{uploaderRole}}) updated the project documents.
                </p>

                <table
                  role='presentation'
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  style='
                    margin: 24px 0;
                    border: 1px solid #e5e7eb;
                    border-radius: 12px;
                    background-color: #f8fafc;
                  '
                >
                  <tr>
                    <td style='padding: 24px'>
                      <p
                        style='
                          margin: 0 0 12px;
                          font-size: 13px;
                          font-weight: bold;
                          color: #475569;
                          text-transform: uppercase;
                          letter-spacing: 0.04em;
                        '
                      >
                        Documents
                      </p>
                      <p style='margin: 0; font-size: 15px; line-height: 1.7'>
                        {{documentNames}}
                      </p>
                    </td>
                  </tr>
                </table>

                <p style='margin: 0; font-size: 15px; line-height: 1.7'>
                  Please sign in to review the latest files.
                </p>

                <p style='margin: 16px 0 0; font-size: 15px; line-height: 1.7'>
                  <a
                    href='{{portalUrl}}'
                    style='color: #c90000; font-weight: 700; text-decoration: none'
                  >
                    Go to Portal
                  </a>
                </p>
              </td>
            </tr>

            <tr>
              <td
                style='
                  padding: 20px 40px 32px;
                  font-size: 13px;
                  line-height: 1.6;
                  color: #64748b;
                '
              >
                This is an automated message. Please do not reply directly to
                this email. For assistance, call {{companyPhone}}.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
